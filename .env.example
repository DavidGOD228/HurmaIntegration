# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
# For docker-compose: injected automatically from docker-compose.yml
# For local dev: set this directly
DATABASE_URL=postgres://hurma_recorder:changeme_in_production@localhost:5432/hurma_recorder

# Used by docker-compose to set the Postgres password (matches DATABASE_URL above)
POSTGRES_PASSWORD=changeme_in_production

# ── Fireflies ─────────────────────────────────────────────────────────────────
# Your Fireflies API key — get from https://app.fireflies.ai/integrations/apps/api
FIREFLIES_API_KEY=your_fireflies_api_key_here

# Secret used to verify the HMAC-SHA256 webhook signature (x-hub-signature header).
# Set this in your Fireflies webhook configuration.
FIREFLIES_WEBHOOK_SECRET=your_fireflies_webhook_secret_here

# ── Hurma ─────────────────────────────────────────────────────────────────────
# Your company's Hurma domain (e.g. https://yourcompany.hurma.work)
HURMA_BASE_URL=https://yourcompany.hurma.work

# Hurma OAuth Bearer access token (from /api/v3/oauth/token)
HURMA_API_TOKEN=your_hurma_oauth_token_here

# ── App ───────────────────────────────────────────────────────────────────────
DEFAULT_TIMEZONE=Europe/Kiev
APP_BASE_URL=https://your-integration-server.example.com
