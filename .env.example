# ════════════════════════════════════════════════════════════════════════════
#  Monorepo .env — copy to .env and fill in real values before starting
#  docker compose up
# ════════════════════════════════════════════════════════════════════════════

# ── Shared PostgreSQL ─────────────────────────────────────────────────────────
# Single postgres instance; both apps get their own database (see postgres/init.sql)
POSTGRES_PASSWORD=change_this_strong_db_password

# ── hurma-recorder ────────────────────────────────────────────────────────────
# Port the hurma-recorder service listens on (internal; exposed via Nginx)
HURMA_RECORDER_PORT=3000

# Fireflies API key — from https://app.fireflies.ai/integrations/apps/api
FIREFLIES_API_KEY=your_fireflies_api_key_here

# Secret used to verify Fireflies webhook HMAC signatures
FIREFLIES_WEBHOOK_SECRET=your_webhook_secret_here

# Hurma instance URL and OAuth Bearer token
HURMA_BASE_URL=https://bestwork.hurma.work
HURMA_API_TOKEN=your_hurma_api_token_here

# ── worklog-dashboard ─────────────────────────────────────────────────────────
# Port the worklog-dashboard service listens on (internal; exposed via Nginx)
WORKLOG_PORT=3200

# Hurma HR API version: v1 for HR module, v3 for ATS (verify at swagger-ui.hurma.work)
HURMA_HR_API_VERSION=v1

# Redmine instance + API key (admin key needed to list users for auto-mapping)
REDMINE_BASE_URL=https://project.mirko.in.ua
REDMINE_API_KEY=xbQWWeN0JAcjyXInwSgg

# Dashboard Basic Auth credentials (protects the entire UI + API)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_admin_password

# Working hours per day and OK delta threshold (hours)
DEFAULT_WORK_HOURS_PER_DAY=8
OK_DELTA_THRESHOLD_HOURS=0.5

# ── mirko-redmine ─────────────────────────────────────────────────────────────
# Port for the Mirko Redmine proxy (same REDMINE_* vars reused above)
MIRKO_REDMINE_PORT=3100

# ── Shared ───────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
DEFAULT_TIMEZONE=Europe/Kiev
APP_BASE_URL=https://hurmarecorder.development-test.website
